{
    "interface_version": 2,
    "name": "MaaLogres",
    "description": "MaaLogres project interface",
    "contact": "QQ 123456789",
    "license": "MIT",
    "welcome": "Welcome to MaaLogres",
    "github": "https://github.com/Chiwa42/MaaLogres",
    "version": "1.0.1",
    "controller": [
        {
            "name": "Win32",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "logres_andapp",
                "screencap": "FramePool",
                "mouse": "SendMessage",
                "keyboard": "PostMessage"
            }
        }
    ],
    "resource": [
        {
            "name": "resource",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "./agent/main.py"
        ]
    },
    "task": [
        {
            "name": "Daily - War God Aura Special Training",
            "entry": "daily_common_start",
            "option": [
                "daily_lesson_set"
            ]
        },
        {
            "name": "Daily - Aura Training",
            "entry": "daily_common_start",
            "option": [
                "daily_lesson_set"
            ]
        },
        {
            "name": "Time Limited",
            "entry": "time_limited_start"
        },
        {
            "name": "Special",
            "entry": "special_start"
        }
    ],
    "option": {
        "daily_lesson_set": {
            "type": "select",
            "cases": [
                {
                    "name": "war_god",
                    "pipeline_override": {
                        "click: daily_lesson_choice": {
                            "next": [
                                "click: daily_lesson_war_god"
                            ]
                        }
                    }
                },
                {
                    "name": "aura_training",
                    "pipeline_override": {
                        "click: daily_lesson_choice": {
                            "next": [
                                "click: daily_lesson_training"
                            ]
                        }
                    }
                }
            ],
            "default_case": "war_god"
        }
    }
}
