{
    "interface_version": 2,
    "name": "MaaLogres",
    "description": "MaaLogres project interface",
    "contact": "QQ 123456789",
    "license": "MIT",
    "welcome": "Welcome to MaaLogres",
    "github": "https://github.com/Chiwa42/MaaLogres",
    "version": "1.0.1",
    "controller": [
        {
            "name": "Win32",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "logres_andapp",
                "screencap": "FramePool",
                "mouse": "SendMessage",
                "keyboard": "PostMessage"
            }
        }
    ],
    "resource": [
        {
            "name": "resource",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "./agent/main.py"
        ]
    },
    "task": [
        {
            "name": "Daily Start",
            "entry": "daily_start"
        }
    ]
}
