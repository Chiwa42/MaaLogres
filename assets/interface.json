{
    "interface_version": 2,
    "name": "MaaLogres",
    "description": "MaaLogres project interface",
    "contact": "QQ 123456789",
    "license": "MIT",
    "welcome": "Welcome to MaaLogres",
    "github": "https://github.com/Chiwa42/MaaLogres",
    "version": "1.0.2",
    "controller": [
        {
            "name": "Win32",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "logres_andapp",
                "screencap": "FramePool",
                "mouse": "SendMessage",
                "keyboard": "PostMessage"
            }
        }
    ],
    "resource": [
        {
            "name": "resource",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "./agent/main.py"
        ]
    },
    "group": [
        {
            "name": "daily",
            "label": "Daily",
            "default_expand": true
        }
    ],
    "task": [
        {
            "name": "Daily - AuraTraining",
            "entry": "daily: AuraTraining",
            "default_check": true,
            "group": [
                "daily"
            ]
        },
        {
            "name": "Daily - WarGodAuraSpecialTraining",
            "entry": "daily: WarGodAuraSpecialTraining",
            "default_check": false,
            "group": [
                "daily"
            ]
        },
        {
            "name": "MyTask1",
            "entry": "MyTask1"
        },
        {
            "name": "MyTask2",
            "entry": "MyTask2"
        },
        {
            "name": "MyTask3",
            "entry": "MyTask3"
        },
        {
            "name": "MyTask4",
            "entry": "MyTask4"
        },
        {
            "name": "OcrTask",
            "entry": "OcrTask"
        }
    ]
}